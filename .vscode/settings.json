{
    "python.defaultInterpreterPath": ".venv/bin/python",
    "python.linting.enabled": true,
    "[python]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 4
    },
    "files.exclude": {
        ".ruff_cache": true,
        ".pytest_cache": true,
        ".git/**": true,
        ".venv/**": true,
        "dist/**": true,
        "build/**": true,
        "*.egg-info": true,
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/*.pyo": true
    }
}
